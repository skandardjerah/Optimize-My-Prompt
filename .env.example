# Anthropic Claude API Configuration
ANTHROPIC_API_KEY=your_api_key_here

# Server Configuration
PORT=3000

# Environment
NODE_ENV=development

# CORS — comma-separated list of allowed origins (your Railway app URL)
# Example: https://myapp.up.railway.app
# Leave empty to default to localhost:3000 (development only)
ALLOWED_ORIGIN=https://your-app.up.railway.app

# Admin secret — protects internal endpoints (/api/logs, /api/stats, /api/analytics, etc.)
# Set to any long random string. Keep this private.
ADMIN_SECRET=replace_with_a_long_random_secret

# JWT secret — used to sign and verify user authentication tokens.
# Set to any long random string (32+ characters). Keep this private.
JWT_SECRET=replace_with_a_long_random_jwt_secret

# Email (SMTP) — required for email verification and password reset
# Use any SMTP provider: Gmail, SendGrid, Resend, Mailgun, etc.
# Example for Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_SECURE=false
# Example for SendGrid: SMTP_HOST=smtp.sendgrid.net, SMTP_PORT=587, SMTP_USER=apikey
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
FROM_EMAIL=OptimizeMyPrompt <no-reply@yourdomain.com>

# Instructions:
# 1. Copy this file and rename it to .env
# 2. Fill in all values above
# 3. Never commit the .env file to Git
# 4. On Railway: set these in the Variables tab, not in a file